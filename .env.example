# =============================================================================
# trading-analysis-tool — Environment Variables
# =============================================================================
# 1) cp .env.example .env
# 2) 아래 키들을 채우세요
# 3) .env는 .gitignore에 등록되어 있어 절대 커밋되지 않습니다
# =============================================================================

# --- Backend: Binance (선택, 없어도 public market data 조회 가능) ---
# https://www.binance.com/en/my/settings/api-management
BINANCE_API_KEY=
BINANCE_API_SECRET=

# --- Backend: Groq (AI 신호 해석용 — Free tier 충분) ---
# https://console.groq.com 에서 무료 발급
# 미설정 시 AI 해설 기능만 비활성, 다른 기능은 정상 동작
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- Backend: 캐시 ---
CACHE_DIR=./data

# --- Backend: 로깅 ---
LOG_LEVEL=INFO

# --- Backend: 서버 ---
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# --- Backend: CORS (콤마 구분) ---
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:8000

# --- Frontend: 런타임 주입 (index.html에서 window.API_BASE_URL로 설정) ---
# API_BASE_URL=http://localhost:8000
